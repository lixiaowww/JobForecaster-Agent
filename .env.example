# Zero-cost deployment — copy to .env and fill only what you need.
# Full guide: docs/DEPLOY.md

# --- LLM (pick one; Groq free tier recommended for public demo) ---
# GROQ_API_KEY=                    # https://console.groq.com (free tier)
# ANTHROPIC_API_KEY=                 # paid — local dev only, not for public demo

# Offline / CI fallback (no API key):
# FORECASTER_MOCK_LLM=1

# --- Optional ingest (leave unset on zero-cost deploy) ---
# TAVILY_API_KEY=
# FRED_API_KEY=

# --- REST API (local or self-hosted only) ---
# FORECASTER_API_KEY=

# --- Config file override ---
# FORECASTER_CONFIG=config.yaml

# --- Chat bots (off by default) ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
