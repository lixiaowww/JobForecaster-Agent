# .streamlit/secrets.toml — EXAMPLE TEMPLATE
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is already in .gitignore.
#
# On Streamlit Community Cloud:
#   Settings → Secrets → paste the contents of this file with real values.

# ── LLM API Keys (at least one required) ──────────────────────────────────────

# Option A — FREE tier via Groq (recommended for zero-cost deployment)
# Get your key at: https://console.groq.com  (no credit card needed)
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxx"

# Option B — Anthropic (paid; only needed if you want Claude-specific features)
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxx"

# ── Optional: BLS API key for higher rate limits ─────────────────────────────
# BLS basic API works without a key (500 req/day). Register at:
# https://data.bls.gov/registrationEngine/  for 500 → 25,000 req/day.
# BLS_API_KEY = ""
